@model IEnumerable<CanopusAirlines.Models.sp_SearchFlights_Result>

@{
    ViewBag.Title = "Arama Sonuçları";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="margin-top: 150px; min-height: 500px;">
    <h2 style="color: #00ADB5; margin-bottom: 30px;">Available Flights</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            <strong>Üzgünüz!</strong> Aradığınız kriterlere uygun uçuş bulunamadı.
            <br />
            <a href="/Home/Index" style="color: #222831; font-weight: bold;">← Ana sayfaya dönüp tekrar deneyin.</a>
        </div>
    }
    else
    {
        <table class="table table-hover" style="background-color: white; border-radius: 10px; overflow: hidden;">
            <thead style="background-color: #222831; color: white;">
                <tr>
                    <th>Flight No</th>
                    <th>Date</th>
                    <th>From</th>
                    <th>To</th>
                    <th>Price</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="font-weight: bold;">@item.flight_number</td>
                        <td>@item.flight_date</td>
                        <td>@item.FromCity</td>
                        <td>@item.ToCity</td>
                        <td style="color: #00ADB5; font-size: 1.2em;">@item.price ₺</td>
                        <td>
                            <button class="btn btn-info btn-sm">Select</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>