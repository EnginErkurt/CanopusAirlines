@{
    ViewBag.Title = "About";
}

@section Styles {
    <link href="~/Content/canopus_about.css" rel="stylesheet" />
}

<div class="hero">
    <h1>About Us</h1>
    <p>Canopus Airlines delivers passengers to their destinations by offering reliable and comfortable flights worldwide.</p>
</div>

<div class="about-content">
    <div class="about-section">
        <h2>Our Story</h2>
        <p>Canopus Airlines was founded in 2010 by a small team with the vision of "Making sky reachable for everyone." We took our name from Canopus, one of the brightest stars in the sky—just like the stars guiding sailors, we safely guide our passengers to their destinations.</p>
        <p>With over 15 years of experience, we now fly to more than 150 destinations across 3 continents. We make a difference in the industry with our experienced team and customer-focused approach.</p>
    </div>

    <div class="about-section">
        <h2>Our Vision</h2>
        <p>To be the world's most preferred airline and turn every journey into an unforgettable experience.</p>
    </div>

    <div class="about-section">
        <h2>Our Mission</h2>
        <p>To provide world-class aviation services by prioritizing safety, quality, and customer satisfaction. To be an environmentally conscious, innovative, and sustainable airline.</p>
    </div>

    <div class="about-section">
        <h2>Our Values</h2>
        <div class="values">
            <div class="value-card">
                <div class="value-icon">🛡️</div>
                <h3>Security</h3>
                <p>Safety is our top priority. We apply the highest safety standards on every flight.</p>
            </div>
            <div class="value-card">
                <div class="value-icon">⭐</div>
                <h3>Quality</h3>
                <p>We aim for perfection in every detail and provide our passengers first-class service.</p>
            </div>
            <div class="value-card">
                <div class="value-icon">💚</div>
                <h3>Sustainability</h3>
                <p>We embrace an approach that is mindful of the future through our environmentally friendly practices.</p>
            </div>
            <div class="value-card">
                <div class="value-icon">🤝</div>
                <h3>Customer Focus</h3>
                <p>We prioritize our passengers' needs and provide service beyond their expectations.</p>
            </div>

            <div class="value-card">
                <div class="value-icon">💡</div>
                <h3>Innovation</h3>
                <p>We continuously adopt new technologies and creative solutions to improve our passengers' travel experience.</p>
            </div>

            <div class="value-card">
                <div class="value-icon">⚙️</div>
                <h3>Efficiency</h3>
                <p>We focus on optimizing time, resources, and performance to deliver a seamless travel experience.</p>
            </div>
        </div>
    </div>
</div>

<div class="stats">
    <div class="stats-content">
        <div class="stat-item">
            <div class="stat-number" id="flights">0</div>
            <div class="stat-label">Daily Flights</div>
        </div>
        <div class="stat-item">
            <div class="stat-number" id="destinations">0</div>
            <div class="stat-label">Destinations</div>
        </div>
        <div class="stat-item">
            <div class="stat-number" id="passengers">0</div>
            <div class="stat-label">25 Million Passengers Every Year</div>
        </div>
    </div>
</div>

<div class="team">
    <h2>Our Management Team</h2>
    <div class="team-grid">
        <div class="team-member">
            <div class="team-avatar">👨‍✈️</div>
            <h3>Engin Erkurt</h3>
            <div class="role">General Manager</div>
            <p>He manages our company with 20 years of aviation experience.</p>
        </div>
        <div class="team-member">
            <div class="team-avatar">👩‍💼</div>
            <h3>Şevval Boyraz</h3>
            <div class="role">Director of Operations</div>
            <p>She ensures that our flight operations run smoothly.</p>
        </div>
        <div class="team-member">
            <div class="team-avatar">👩‍✈️</div>
            <h3>Meryem Abdulrahman</h3>
            <div class="role">Terminal Director</div>
            <p>She manages all operations at the airport terminal.</p>
        </div>
        <div class="team-member">
            <div class="team-avatar">👩‍💼</div>
            <h3>Samira Yıldız</h3>
            <div class="role">Director of Customer Service</div>
            <p>She maintains customer satisfaction at the highest level.</p>
        </div>
        <div class="team-member">
            <div class="team-avatar">👩‍✈️</div>
            <h3>Sıla Yahşi</h3>
            <div class="role">Security Director</div>
            <p>She manages all the security protocols.</p>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/Scripts/canopus_about.js"></script>
}