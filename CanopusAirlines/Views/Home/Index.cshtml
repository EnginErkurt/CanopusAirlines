<div class="flight-finder">
    <form action="@Url.Action("Search", "Home")" method="get">

        <div class="trip-type">
            <label>
                <input type="radio" name="trip" value="round" checked> Round trip
            </label>
            <label>
                <input type="radio" name="trip" value="oneway"> One Way
            </label>
        </div>

        <div class="flight-inputs">
            <div class="input-group">
                <label>From</label>
                <select name="from_id" class="form-control" style="width: 100%; padding: 10px; border: none; outline: none;">
                    <option value="">Select Origin</option>
                    @if (ViewBag.Airports != null)
                    {
                        foreach (var airport in ViewBag.Airports)
                        {
                            <option value="@airport.airport_id">@airport.city (@airport.iata)</option>
                        }
                    }
                </select>
            </div>

            <div class="input-group">
                <label>To</label>
                <select name="to_id" class="form-control" style="width: 100%; padding: 10px; border: none; outline: none;">
                    <option value="">Select Destination</option>
                    @if (ViewBag.Airports != null)
                    {
                        foreach (var airport in ViewBag.Airports)
                        {
                            <option value="@airport.airport_id">@airport.city (@airport.iata)</option>
                        }
                    }
                </select>
            </div>

            <div class="input-group">
                <label>Departure</label>
                <input type="date" name="flight_date" required>
            </div>

            <div class="input-group" id="return-date-group">
                <label>Return</label>
                <input type="date" id="return">
            </div>

            <div class="input-group">
                <label>Passengers</label>
                <select id="passengers">
                    <option value="1">1 Passenger</option>
                    <option value="2">2 Passenger</option>
                    <option value="3">3+ Passenger</option>
                </select>
            </div>

            <div class="input-group">
                <label>Class</label>
                <select id="class">
                    <option value="Economy">Economy</option>
                    <option value="Business">Business</option>
                </select>
            </div>
        </div>

        <button type="submit" class="btn-search">Search Flights</button>
    </form>
</div>

<div class="quick-links">
    <div class="link-card" onclick="alert('Check-in page is coming soon!')">
        <h3>Online Check-in</h3>
        <p>You can check in online 24 hours before your flight.</p>
    </div>
    <a href="@Url.Action("AirportServices", "Home")" class="link-card" style="text-decoration: none; color: inherit; display: block;">
        <h3>Airport Services</h3>
        <p>Discover our lounge, baggage, and transportation services.</p>
    </a>
    <div class="link-card" onclick="alert('Reservation Management page is coming soon!')">
        <h3>My Reservations</h3>
        <p>View and manage your current reservations.</p>
    </div>
</div>

<div class="destinations">
    <h2>Popular Destinations</h2>
    <div class="destination-cards">
        <div class="destination-card">
            <a href="@Url.Action("EuropeDestinations", "Home")" class="destination-img-europe"></a>
            <div class="destination-info">
                <h3>Europe</h3>
                <p>Fly to Paris, London, Rome, Berlin, and more European cities.</p>
            </div>
        </div>
        <div class="destination-card">
            <a href="@Url.Action("AmericaDestinations", "Home")" class="destination-img-america"></a>
            <div class="destination-info">
                <h3>North America</h3>
                <p>Discover cities like New York, Los Angeles, and Toronto.</p>
            </div>
        </div>
        <div class="destination-card">
            <a href="@Url.Action("AsiaDestinations", "Home")" class="destination-img-asia"></a>
            <div class="destination-info">
                <h3>Asia</h3>
                <p>Tokyo, Dubai, Singapore, and more destinations in Asia.</p>
            </div>
        </div>
    </div>
</div>

