@model CanopusAirlines.Models.BookingViewModel
@{
    ViewBag.Title = "Yolcu Bilgileri";
    Layout = "~/Views/Shared/_Layout.cshtml"; /* ARTIK ANA ŞABLONU KULLANIYORUZ */
}

<link rel="stylesheet" href="@Url.Content("~/Content/PassengerStyle.css")">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<div class="main-wrapper" style="padding-top: 160px; padding-bottom: 50px;">
    <div class="container">

        <div class="page-title">
            <h1>Passenger Details</h1>
            <p>Flight Info: @Model.OutboundFlight.flight_number</p>
        </div>

        @using (Html.BeginForm("SeatSelection", "Home", FormMethod.Post, new { id = "bookingForm" }))
        {
            @Html.HiddenFor(m => m.OutboundFlightId)
            @Html.HiddenFor(m => m.InboundFlightId) @Html.HiddenFor(m => m.TotalPrice)

            <div class="card">
                <div class="card-header"><i class="fa-solid fa-user"></i> Passenger Information</div>
                <div class="card-body">
                    <div class="row">
                        <div class="form-group half">
                            <label>First Name</label>
                            @Html.TextBoxFor(m => m.FirstName, new { required = "required", placeholder = "John" })
                        </div>
                        <div class="form-group half">
                            <label>Last Name</label>
                            @Html.TextBoxFor(m => m.LastName, new { required = "required", placeholder = "Doe" })
                        </div>
                    </div>
                    <div class="row">
                        <div class="form-group half">
                            <label>Gender</label>
                            <div class="gender-select">
                                <label class="radio-container">
                                    Male
                                    @Html.RadioButtonFor(m => m.Gender, "Male")
                                    <span class="checkmark"></span>
                                </label>
                                <label class="radio-container">
                                    Female
                                    @Html.RadioButtonFor(m => m.Gender, "Female")
                                    <span class="checkmark"></span>
                                </label>
                            </div>
                        </div>
                        <div class="form-group half">
                            <label>Date of Birth</label>
                            <input type="date" name="BirthDate" required>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><i class="fa-solid fa-address-book"></i> Contact</div>
                <div class="card-body">
                    <div class="row">
                        <div class="form-group half">
                            <label>Email</label>
                            @Html.TextBoxFor(m => m.Email, new { type = "email", required = "required" })
                        </div>
                        <div class="form-group half">
                            <label>Phone</label>
                            @Html.TextBoxFor(m => m.Phone, new { type = "tel", required = "required" })
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><i class="fa-solid fa-credit-card"></i> Payment (Demo)</div>
                <div class="card-body">
                    <input type="text" placeholder="Card Number (Demo)" class="form-control" style="width:100%; padding:10px;">
                </div>
            </div>

            <div class="action-area">
                <div class="total-price">
                    <span>Base Price:</span>
                    <strong>@Model.TotalPrice.ToString("N2") ₺</strong>
                </div>
                <button type="submit" id="btnNext" class="btn-next">
                    Go to Seat Selection <i class="fa-solid fa-arrow-right"></i>
                </button>
            </div>
        }
    </div>
</div>

<script src="@Url.Content("~/Scripts/PassengerScript.js")"></script>