@{
    ViewBag.Title = "Giriş Yap";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="margin-top: 100px; max-width: 400px;">
    <div class="card shadow-lg p-4">
        <h2 class="text-center text-primary mb-4">Hoşgeldiniz</h2>

        <form action="/Auth/Login" method="post">
            <div class="form-group mb-3">
                <label>Email</label>
                <input type="email" name="email" class="form-control" placeholder="Email adresiniz" required />
            </div>

            <div class="form-group mb-3">
                <label>Şifre</label>
                <input type="password" name="password" class="form-control" placeholder="Şifreniz" required />
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <button type="submit" class="btn btn-primary w-100">Giriş Yap</button>
        </form>

        <div class="text-center mt-3">
            <p>Hesabın yok mu? <a href="/Auth/Register">Kayıt Ol</a></p>
        </div>
    </div>
</div>